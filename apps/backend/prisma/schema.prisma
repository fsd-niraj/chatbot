generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Multi-tenancy: shared schema, all tenant rows scoped by org_id
// ---------------------------------------------------------------------------

model Organization {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users            User[]
  chatbotInstances ChatbotInstance[]
  llmApiKeys       LlmApiKey[]

  @@map("organizations")
}

model User {
  id           String   @id @default(uuid())
  orgId        String   @map("org_id")
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         UserRole @default(ORG_ADMIN)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@map("users")
}

enum UserRole {
  MASTER_ADMIN
  ORG_ADMIN
  ORG_MEMBER
}

model ChatbotInstance {
  id         String   @id @default(uuid())
  orgId      String   @map("org_id")
  name       String
  publicKey  String   @unique @map("public_key")
  privateKey String   @unique @map("private_key")
  /// JSON: ChatbotConfig — theme, welcomeMessage, botName, modelConfig
  config     Json     @default("{}")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  organization       Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  conversations      Conversation[]
  analyticsSnapshots AnalyticsSnapshot[]

  @@index([orgId])
  @@index([publicKey])
  @@map("chatbot_instances")
}

model LlmApiKey {
  id           String      @id @default(uuid())
  orgId        String      @map("org_id")
  provider     LlmProvider
  /// AES-256 encrypted API key — never returned to client plain-text
  encryptedKey String      @map("encrypted_key")
  /// JSON: Partial<ModelConfig> — provider-specific model settings
  modelConfig  Json        @default("{}") @map("model_config")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, provider])
  @@map("llm_api_keys")
}

enum LlmProvider {
  openai
  anthropic
}

model Conversation {
  id                String   @id @default(uuid())
  chatbotInstanceId String   @map("chatbot_instance_id")
  /// Unique browser session UUID (stored in localStorage by widget)
  browserSessionId  String   @map("browser_session_id")
  createdAt         DateTime @default(now()) @map("created_at")

  chatbotInstance ChatbotInstance @relation(fields: [chatbotInstanceId], references: [id], onDelete: Cascade)
  messages        Message[]

  @@index([chatbotInstanceId])
  @@index([browserSessionId])
  @@map("conversations")
}

model Message {
  id             String   @id @default(uuid())
  conversationId String   @map("conversation_id")
  /// 'user' | 'assistant'
  role           String
  content        String
  tokensUsed     Int?     @map("tokens_used")
  latencyMs      Int?     @map("latency_ms")
  createdAt      DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([createdAt])
  @@map("messages")
}

// Raw event log — every analytics event published through RabbitMQ lands here.
// Used for ad-hoc queries, reprocessing, and audit trail.
model Event {
  id        String   @id @default(uuid())
  /// Matches AnalyticsEvent.type from @chatbot/shared
  type      String
  chatbotId String   @map("chatbot_id")
  orgId     String   @map("org_id")
  /// Full event payload as JSON (AnalyticsEvent shape)
  payload   Json
  /// When the event actually occurred (from event.occurredAt, not insert time)
  occurredAt DateTime @map("occurred_at")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([chatbotId, type, occurredAt])
  @@index([orgId, occurredAt])
  @@map("events")
}

model AnalyticsSnapshot {
  id                String   @id @default(uuid())
  chatbotInstanceId String   @map("chatbot_instance_id")
  date              DateTime
  /// 'hour' | 'day'
  period            String
  /// JSON: matches AnalyticsOverview shape (partial, for the period window)
  metrics           Json
  createdAt         DateTime @default(now()) @map("created_at")

  chatbotInstance ChatbotInstance @relation(fields: [chatbotInstanceId], references: [id], onDelete: Cascade)

  @@unique([chatbotInstanceId, date, period])
  @@index([chatbotInstanceId, date])
  @@map("analytics_snapshots")
}
