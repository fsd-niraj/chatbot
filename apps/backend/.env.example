# Server
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/chatbot_platform

# Auth
JWT_SECRET=change_me_to_a_long_random_secret_at_least_64_chars
JWT_EXPIRY=7d

# Encryption (AES-256 for LLM API keys at rest — must be 32 chars)
ENCRYPTION_KEY=change_me_to_32_char_secret_key_!

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Master admin (hardcoded — set this email to grant MASTER_ADMIN on register)
MASTER_ADMIN_EMAIL=admin@example.com
